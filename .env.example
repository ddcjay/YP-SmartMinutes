# ===== 應用設定 =====
APP_ENV=development
APP_DEBUG=true

# ===== AI 服務 =====
GEMINI_API_KEY=your-gemini-api-key     # Google Gemini API Key（免費額度，也可在前端設定頁面輸入）

# ===== 檔案儲存 =====
UPLOAD_DIR=./uploads                   # 音檔暫存路徑
MAX_FILE_SIZE_MB=500                   # 單檔最大上傳大小
FILE_RETENTION_HOURS=24                # 音檔保留時間（小時）
